generator client {
  provider = "prisma-client-js"
  // use default output (node_modules/.prisma/client) to avoid ESM/CommonJS mismatch
}

datasource db {
  provider = "postgresql"
}

// Full schema generated from ER diagram

// Enums added to match ER diagram
enum Role {
  ADMIN
  USER
}

enum Permission {
  VIEW
  EDIT
}

enum StorageType {
  LOCAL
  S3
}

enum BillingStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WebhookEventStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id                String    @id @default(uuid())
  name              String?
  avatar_url        String?
  email             String    @unique
  password          String
  role              Role      @default(USER)
  email_verified_at DateTime?
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleted_at        DateTime?

  refreshTokens        RefreshToken[]
  folders              Folder[]
  files                File[]
  subscriptions        UserSubscription[]
  billing              BillingTransaction[]
  storageUsage         StorageUsage?
  activityLogs         ActivityLog[]
  webhooks             Webhook[]
  folderShares         FolderShare[]        @relation("FolderShareCreatedBy")
  fileShares           FileShare[]          @relation("FileShareCreatedBy")
  publicShares         PublicShare[]        @relation("PublicShareCreatedBy")
  folderSharesWithUser FolderShare[]        @relation("FolderShareWithUser")
  fileSharesWithUser   FileShare[]          @relation("FileShareWithUser")
}

model RefreshToken {
  id         String    @id @default(uuid())
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  token_hash String    @unique
  expires_at DateTime?
  is_revoked Boolean   @default(false)
  created_at DateTime  @default(now())
  revoked_at DateTime?
}

model SubscriptionPackage {
  id               String    @id @default(uuid())
  name             String    @unique
  max_folders      Int?
  max_file_size_mb Int?
  max_storage_mb   Int?
  trial_days       Int?
  price            Decimal?  @db.Decimal(10, 2)
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?

  userSubscriptions UserSubscription[]
  allowedFileTypes  PackageAllowedFileType[]
}

model PackageAllowedFileType {
  id                    String              @id @default(uuid())
  subscriptionPackage   SubscriptionPackage @relation(fields: [subscriptionPackageId], references: [id])
  subscriptionPackageId String
  mime_type             String
  created_at            DateTime            @default(now())
}

model Folder {
  id         String    @id @default(uuid())
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  parentId   String?
  parent     Folder?   @relation("FolderChildren", fields: [parentId], references: [id])
  children   Folder[]  @relation("FolderChildren")
  name       String
  path       String
  is_deleted Boolean   @default(false)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  files        File[]
  folderShares FolderShare[]
  publicShares PublicShare[]

  @@index([parentId, userId])
}

model File {
  id           String       @id @default(uuid())
  user         User         @relation(fields: [userId], references: [id])
  userId       String
  folder       Folder?      @relation(fields: [folderId], references: [id])
  folderId     String?
  name         String
  path         String
  mime_type    String
  size_bytes   BigInt
  storage_type StorageType? // e.g., LOCAL, S3
  storage_key  String?
  checksum     String?
  downloads    Int          @default(0)
  is_deleted   Boolean      @default(false)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  deleted_at   DateTime?

  fileShares   FileShare[]
  publicShares PublicShare[]

  @@index([folderId])
  @@index([userId])
  @@index([checksum])
  @@index([userId, name])
}

model UserSubscription {
  id                  String               @id @default(uuid())
  user                User                 @relation(fields: [userId], references: [id])
  userId              String
  package             SubscriptionPackage  @relation(fields: [packageId], references: [id])
  packageId           String
  started_at          DateTime             @default(now())
  ended_at            DateTime?
  is_active           Boolean              @default(true)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  billingTransactions BillingTransaction[]

  @@index([userId, is_active])
}

model BillingTransaction {
  id             String            @id @default(uuid())
  user           User              @relation(fields: [userId], references: [id])
  userId         String
  subscription   UserSubscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId String?
  amount         Decimal           @db.Decimal(12, 2)
  currency       String
  status         BillingStatus
  provider       String?
  reference      String?
  paid_at        DateTime?
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  @@index([userId])
  @@index([subscriptionId])
}

model StorageUsage {
  id                  String   @id @default(uuid())
  user                User     @relation(fields: [userId], references: [id])
  userId              String   @unique
  total_storage_bytes BigInt   @default(0)
  total_files         Int      @default(0)
  total_folders       Int      @default(0)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}

model FolderShare {
  id               String     @id @default(uuid())
  folder           Folder     @relation(fields: [folderId], references: [id])
  folderId         String
  shared_with_user User?      @relation("FolderShareWithUser", fields: [sharedWithUserId], references: [id])
  sharedWithUserId String?
  permission       Permission // VIEW, EDIT, etc.
  created_by       User?      @relation("FolderShareCreatedBy", fields: [createdById], references: [id])
  createdById      String?
  created_at       DateTime   @default(now())

  @@unique([folderId, sharedWithUserId])
}

model FileShare {
  id               String     @id @default(uuid())
  file             File       @relation(fields: [fileId], references: [id])
  fileId           String
  shared_with_user User       @relation("FileShareWithUser", fields: [sharedWithUserId], references: [id])
  sharedWithUserId String
  permission       Permission // VIEW, EDIT
  created_by       User?      @relation("FileShareCreatedBy", fields: [createdById], references: [id])
  createdById      String?
  created_at       DateTime   @default(now())

  @@unique([fileId, sharedWithUserId])
}

// Business rule: exactly one of fileId or folderId must be non-null
model PublicShare {
  id           String    @id @default(uuid())
  file         File?     @relation(fields: [fileId], references: [id])
  fileId       String?
  folder       Folder?   @relation(fields: [folderId], references: [id])
  folderId     String?
  public_token String    @unique
  public_url   String?
  is_active    Boolean   @default(true)
  expires_at   DateTime?
  created_by   User      @relation("PublicShareCreatedBy", fields: [createdById], references: [id])
  createdById  String
  created_at   DateTime  @default(now())
}

model ActivityLog {
  id          String   @id @default(uuid())
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  action_type String
  entity_type String
  entity_id   String?
  ip_address  String?
  created_at  DateTime @default(now())
}

model Webhook {
  id         String   @id @default(uuid())
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  url        String
  secret     String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  events WebhookEvent[]
}

model WebhookEvent {
  id          String             @id @default(uuid())
  webhook     Webhook            @relation(fields: [webhookId], references: [id])
  webhookId   String
  event_type  String
  payload     Json?
  status      WebhookEventStatus // PENDING, SUCCESS, FAILED
  retry_count Int                @default(0)
  created_at  DateTime           @default(now())
}

// Add any indexes or constraints below as needed
